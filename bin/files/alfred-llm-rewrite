#!/usr/bin/env bash

# Alfred text rewrite helper.
# Runtime behavior lives here so it can be syntax-checked and tested without
# fighting Nix string escaping. Profile-specific values are generated by Home
# Manager into ~/.config/alfred-llm-rewrite/config.env.

set -u

CONFIG_FILE="${ALFRED_LLM_CONFIG:-$HOME/.config/alfred-llm-rewrite/config.env}"
MAX_TOKENS="${ALFRED_LLM_MAX_TOKENS:-512}"
OP_ENV_CACHE_BIN="${OP_ENV_CACHE_BIN:-$HOME/.local/bin/op-env-cache}"
MODE=""
USER_TEXT=""
PROMPT_FILE=""

fail() {
  echo "ERROR${PROVIDER:+ ($PROVIDER)}: $*"
  exit 0
}

load_config() {
  [ -f "$CONFIG_FILE" ] || fail "config file not found: $CONFIG_FILE"

  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
}

parse_args() {
  if [ "${1:-}" = "--mode" ] && [ $# -ge 3 ]; then
    MODE="$2"
    USER_TEXT="$3"
  elif [[ "${1:-}" == --mode=* ]] && [ $# -ge 2 ]; then
    MODE="${1#--mode=}"
    USER_TEXT="$2"
  else
    echo "ERROR: usage: alfred-openai-rewrite --mode grammar|tone \"text\""
    exit 0
  fi
}

set_prompt_file() {
  case "$MODE" in
    grammar) PROMPT_FILE="$HOME/dotfiles/config/ai/grammar-fixer-prompt.md" ;;
    tone) PROMPT_FILE="$HOME/dotfiles/config/ai/tone-fixer-prompt.md" ;;
    *) fail "unsupported mode '$MODE' (expected: grammar|tone)" ;;
  esac
}

build_request_body() {
  TOKEN_FIELD="max_tokens"
  REASONING_EFFORT=""

  case "$PROVIDER" in
    OpenAI)
      TOKEN_FIELD="max_completion_tokens"
      REASONING_EFFORT="low"
      ;;
    Cerebras) ;;
    *) fail "unsupported provider: $PROVIDER" ;;
  esac

  jq -n \
    --arg model "$MODEL" \
    --arg system "$SYSTEM_PROMPT" \
    --arg user "$USER_TEXT" \
    --arg token_field "$TOKEN_FIELD" \
    --arg reasoning_effort "$REASONING_EFFORT" \
    --argjson max_tokens "$MAX_TOKENS" \
    '{
      model: $model,
      messages: [
        {role: "system", content: $system},
        {role: "user", content: $user}
      ]
    }
    + {($token_field): $max_tokens}
    + (if $reasoning_effort == "" then {} else {reasoning_effort: $reasoning_effort} end)'
}

load_key() {
  KEY=$("$OP_ENV_CACHE_BIN" get "$CACHE_NAME" "$SECRET_ENV" --account "$OP_ACCOUNT" --auto-refresh --sops-file "$SOPS_SPEC_FILE" 2>&1) || fail "$KEY"
}

main() {
  PROVIDER=""
  load_config
  parse_args "$@"

  set_prompt_file
  if [ ! -f "$PROMPT_FILE" ]; then
    fail "prompt file not found: $PROMPT_FILE"
  fi

  # Normalize whitespace to reduce token overhead.
  SYSTEM_PROMPT=$(tr '\n' ' ' <"$PROMPT_FILE" | tr -s '[:space:]' ' ')

  load_key

  REQUEST_BODY=$(build_request_body) || fail "failed to build request JSON"

  RESPONSE=$(curl -sS --connect-timeout 2 --max-time 5 "$BASE_URL/chat/completions" \
    -H "Authorization: Bearer $KEY" \
    -H "Content-Type: application/json" \
    -d "$REQUEST_BODY")

  if [ -z "$RESPONSE" ]; then
    fail "empty response"
  fi

  echo "$RESPONSE" | jq -r 'if .error then "ERROR (" + $provider + "): " + (.error.message // "unknown") elif .message then "ERROR (" + $provider + "): " + (.message // "unknown") else .choices[0].message.content end' --arg provider "$PROVIDER"
}

main "$@"
