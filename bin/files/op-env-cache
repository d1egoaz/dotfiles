#!/usr/bin/env zsh
# Cache SOPS-defined 1Password refs as raw value files.
# zsh is intentional: this is a macOS dotfiles helper invoked directly.

set -euo pipefail

prog="op-env-cache"
default_ttl="${OP_ENV_CACHE_MAX_AGE_SECONDS:-28800}"
cmd="${1:-}"
name=""
key=""
account=""
cache_override=""
sops_file=""
max_age=""
ttl=""
auto_refresh=0
cache_root=""
spec=""

die() { print -ru2 -- "$prog: $*"; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "'$1' is not available in PATH"; }
usage() {
  cat >&2 <<'EOF'
Usage:
  op-env-cache get NAME KEY --sops-file FILE [--account ACCOUNT] [--cache-dir DIR] [--max-age SECONDS] [--auto-refresh]
  op-env-cache refresh NAME --sops-file FILE [--account ACCOUNT] [--cache-dir DIR]
  op-env-cache status NAME --sops-file FILE [--account ACCOUNT] [--cache-dir DIR] [--max-age SECONDS]
  op-env-cache path NAME [--cache-dir DIR]
  op-env-cache logout NAME [--cache-dir DIR]
  op-env-cache clear NAME [--cache-dir DIR]
EOF
}

parse_options() {
  while (( $# > 0 )); do
    case "$1" in
      --account) (( $# >= 2 )) || die "--account requires a value"; account="$2"; shift 2 ;;
      --cache-dir|--cache-file) (( $# >= 2 )) || die "$1 requires a value"; cache_override="$2"; shift 2 ;;
      --sops-file) (( $# >= 2 )) || die "--sops-file requires a value"; sops_file="$2"; shift 2 ;;
      --max-age) (( $# >= 2 )) || die "--max-age requires a value"; max_age="$2"; shift 2 ;;
      --auto-refresh) auto_refresh=1; shift ;;
      --*) die "unknown option: $1" ;;
      *) die "unexpected argument: $1" ;;
    esac
  done
}

sha256_text() {
  print -rn -- "$1" | shasum -a 256 | while read -r digest _rest; do print -r -- "$digest"; done
}

cache_path() {
  [[ -n "$cache_override" ]] && { print -r -- "$cache_override"; return; }
  local base="${OP_ENV_CACHE_DIR:-${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}}"
  print -r -- "${base%/}/op-env-cache/$(sha256_text "$name")"
}

legacy_cache_path() {
  [[ -z "$cache_override" && "$name" != */* ]] || return 1
  local base="${OP_ENV_CACHE_DIR:-${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}}"
  print -r -- "${base%/}/op-env-cache/$name.json"
}

mode_of() { /usr/bin/stat -f '%Lp' "$1" 2>/dev/null; }
value_path() { print -r -- "$cache_root/$(sha256_text "$1").value"; }
value_path_in() { print -r -- "$1/$(sha256_text "$2").value"; }
file_hash() { shasum -a 256 "$1" | while read -r digest _rest; do print -r -- "$digest"; done; }

fast_get() {
  # On a warm hit this prints the secret and exits before loading SOPS.
  [[ -n "$sops_file" && -r "$sops_file" ]] || return 1
  local target account_file created_file ttl_file sops_hash_file created cached_ttl now
  target=$(value_path "$key")
  created_file="$target.created_at"
  ttl_file="$target.ttl"
  sops_hash_file="$target.sops_hash"
  account_file="$target.account"
  [[ -d "$cache_root" && "$(mode_of "$cache_root")" == "700" ]] || return 1
  [[ -f "$cache_root/.op-env-cache" && "$(<"$cache_root/.op-env-cache")" == "$name" ]] || return 1
  [[ -s "$target" && "$(mode_of "$target")" == "600" ]] || return 1
  [[ -s "$created_file" && "$(mode_of "$created_file")" == "600" ]] || return 1
  [[ -s "$ttl_file" && "$(mode_of "$ttl_file")" == "600" ]] || return 1
  [[ -s "$sops_hash_file" && "$(mode_of "$sops_hash_file")" == "600" ]] || return 1
  [[ -f "$account_file" && "$(mode_of "$account_file")" == "600" ]] || return 1
  [[ -z "$account" || "$(<"$account_file")" == "$account" ]] || return 1
  created="$(<"$created_file")"
  cached_ttl="${max_age:-$(<"$ttl_file")}"
  [[ "$created" == <-> && "$cached_ttl" == <-> ]] || return 1
  [[ "$(<"$sops_hash_file")" == "$(file_hash "$sops_file")" ]] || return 1
  (( cached_ttl == 0 )) && { /bin/cat "$target"; exit 0; }
  now=$(date -u +%s)
  (( now - created <= cached_ttl )) || return 1
  /bin/cat "$target"
  exit 0
}

load_spec() {
  [[ -n "$sops_file" ]] || die "--sops-file is required"
  [[ -r "$sops_file" ]] || die "SOPS file is not readable: $sops_file"
  need sops
  need jq

  local extract
  extract=$(jq -nr --arg name "$name" '"[\"op_env_cache_specs\"][\($name | @json)]"')
  local age_key="${SOPS_AGE_KEY_FILE:-$HOME/Library/Application Support/sops/age/keys.txt}"
  local err
  err=$(mktemp "${TMPDIR:-/tmp}/op-env-cache-sops.XXXXXX") || die "failed to create temp error file"
  if [[ -f "$age_key" ]]; then
    spec=$(SOPS_AGE_KEY_FILE="$age_key" sops --decrypt --output-type json --extract "$extract" "$sops_file" 2>"$err") || {
      local msg="$(<"$err")"
      rm -f "$err"
      die "failed to decrypt SOPS spec: $msg"
    }
  else
    spec=$(sops --decrypt --output-type json --extract "$extract" "$sops_file" 2>"$err") || {
      local msg="$(<"$err")"
      rm -f "$err"
      die "failed to decrypt SOPS spec: $msg"
    }
  fi
  rm -f "$err"

  print -r -- "$spec" | jq -e '.env | type == "object" and length > 0' >/dev/null || die "SOPS spec must define a non-empty env object: $name"
  [[ -n "$account" ]] || account=$(print -r -- "$spec" | jq -er '.account // ""')
  if [[ -n "$max_age" ]]; then
    ttl=$(jq -nr --arg ttl "$max_age" '$ttl | tonumber | floor | tostring') || die "invalid --max-age: $max_age"
  else
    ttl=$(print -r -- "$spec" | jq -er --arg default "$default_ttl" '(.cache_ttl_seconds // ($default | tonumber)) | floor | tostring') || die "invalid cache ttl"
  fi
}

spec_refs() {
  print -r -- "$spec" | jq -r '.env | to_entries[] | [.key, .value] | @tsv'
}

ref_for_key() {
  local ref_key ref_value
  while IFS=$'\t' read -r ref_key ref_value; do
    [[ "$ref_key" == "$key" ]] && { print -r -- "$ref_value"; return 0; }
  done < <(spec_refs)
  return 1
}

value_is_fresh() {
  local target
  target=$(value_path "$1")
  local created_file="$target.created_at"
  local ttl_file="$target.ttl"
  local sops_hash_file="$target.sops_hash"
  local account_file="$target.account"
  [[ -d "$cache_root" && "$(mode_of "$cache_root")" == "700" ]] || return 1
  [[ -s "$target" && "$(mode_of "$target")" == "600" ]] || return 1
  [[ -s "$created_file" && "$(mode_of "$created_file")" == "600" ]] || return 1
  [[ -s "$ttl_file" && "$(mode_of "$ttl_file")" == "600" ]] || return 1
  [[ -s "$sops_hash_file" && "$(mode_of "$sops_hash_file")" == "600" ]] || return 1
  [[ -f "$account_file" && "$(mode_of "$account_file")" == "600" ]] || return 1
  [[ -f "$cache_root/.op-env-cache" && "$(<"$cache_root/.op-env-cache")" == "$name" ]] || return 1
  [[ "$(<"$sops_hash_file")" == "$(file_hash "$sops_file")" ]] || return 1
  [[ "$(<"$account_file")" == "$account" ]] || return 1
  (( ttl == 0 )) && return 0
  local now created
  now=$(date -u +%s)
  created="$(<"$created_file")"
  [[ "$created" == <-> ]] || return 1
  (( now - created <= ttl ))
}

write_file() {
  local target="$1"
  local value="$2"
  local tmp
  tmp=$(mktemp "$target.XXXXXX") || die "failed to create temp file for $target"
  chmod 600 "$tmp"
  print -rn -- "$value" > "$tmp"
  mv -f "$tmp" "$target" || { rm -f "$tmp"; die "failed to write $target"; }
}

write_op_value() {
  local ref="$1"
  local target="$2"
  local tmp err
  local -a op_cmd=(op read)
  [[ -n "$account" ]] && op_cmd+=(--account "$account")
  tmp=$(mktemp "$target.XXXXXX") || die "failed to create temp file for $target"
  err=$(mktemp "${TMPDIR:-/tmp}/op-env-cache-op.XXXXXX") || { rm -f "$tmp"; die "failed to create temp error file"; }
  chmod 600 "$tmp"
  if ! "${op_cmd[@]}" "$ref" >"$tmp" 2>"$err"; then
    cat "$err" >&2
    rm -f "$tmp" "$err"
    die "failed to read secret from 1Password"
  fi
  rm -f "$err"
  mv -f "$tmp" "$target" || { rm -f "$tmp"; die "failed to write $target"; }
}

owned_or_absent() {
  [[ ! -e "$cache_root" ]] && return
  [[ -d "$cache_root" && -f "$cache_root/.op-env-cache" && "$(<"$cache_root/.op-env-cache")" == "$name" ]] \
    || die "refusing to replace unowned cache path: $cache_root"
}

refresh_cache() {
  owned_or_absent
  local parent tmp_root old_root=""
  parent=$(/usr/bin/dirname "$cache_root")
  mkdir -p "$parent"
  tmp_root=$(mktemp -d "$parent/$(sha256_text "$name").XXXXXX") || die "failed to create temp cache directory"
  chmod 700 "$tmp_root"
  trap "rm -rf ${(q)tmp_root}" EXIT
  trap "rm -rf ${(q)tmp_root}; exit 130" INT TERM
  write_file "$tmp_root/.op-env-cache" "$name"

  local ref_key ref_value now sops_hash
  now=$(date -u +%s)
  sops_hash=$(file_hash "$sops_file")
  while IFS=$'\t' read -r ref_key ref_value; do
    local target
    target=$(value_path_in "$tmp_root" "$ref_key")
    write_op_value "$ref_value" "$target"
    write_file "$target.created_at" "$now"
    write_file "$target.ttl" "$ttl"
    write_file "$target.sops_hash" "$sops_hash"
    write_file "$target.account" "$account"
  done < <(spec_refs)
  if [[ -e "$cache_root" ]]; then
    old_root="$parent/$(sha256_text "$name").old.$$"
    rm -rf "$old_root"
    mv "$cache_root" "$old_root"
  fi
  if ! mv "$tmp_root" "$cache_root"; then
    [[ -n "$old_root" && -e "$old_root" ]] && mv "$old_root" "$cache_root"
    die "failed to install cache: $cache_root"
  fi
  [[ -n "$old_root" ]] && rm -rf "$old_root"
  trap - EXIT INT TERM
  print -ru2 -- "$prog: cached $name at $cache_root"
}

get_cache() {
  local ref_value
  fast_get || true
  load_spec
  ref_value=$(ref_for_key) || die "$key is not in cache spec: $name"
  if ! value_is_fresh "$key"; then
    (( auto_refresh )) || die "no valid cache for '$name'; run: $prog refresh $name, or pass --auto-refresh"
    refresh_cache
  fi
  value_is_fresh "$key" || die "refreshed cache does not contain $key"
  /bin/cat "$(value_path "$key")"
}

status_cache() {
  local status_key ref_value
  load_spec
  while IFS=$'\t' read -r status_key ref_value; do
    value_is_fresh "$status_key" || die "no valid cache at $cache_root"
  done < <(spec_refs)
  print -r -- "$prog: cache ready for $name at $cache_root"
}

[[ -n "$cmd" ]] || { usage; exit 1; }
shift
case "$cmd" in
  refresh|status|path|logout|clear) (( $# >= 1 )) || die "$cmd requires NAME"; name="$1"; shift ;;
  get) (( $# >= 2 )) || die "get requires NAME and KEY"; name="$1"; key="$2"; shift 2 ;;
  -h|--help|help) usage; exit 0 ;;
  *) usage; die "unknown command: $cmd" ;;
esac

parse_options "$@"
cache_root="$(cache_path)"

case "$cmd" in
  refresh)
    load_spec
    refresh_cache
    ;;
  get)
    get_cache
    ;;
  status)
    status_cache
    ;;
  path)
    print -r -- "$cache_root"
    ;;
  logout|clear)
    removed=0
    legacy_cache=""
    if [[ -e "$cache_root" ]]; then
      owned_or_absent
      rm -rf -- "$cache_root"
      print -r -- "$prog: removed $cache_root"
      removed=1
    fi
    if legacy_cache=$(legacy_cache_path) && [[ -e "$legacy_cache" ]]; then
      rm -f -- "$legacy_cache"
      print -r -- "$prog: removed legacy cache $legacy_cache"
      removed=1
    fi
    if (( ! removed )); then
      print -r -- "$prog: no cache at $cache_root"
    fi
    ;;
esac
