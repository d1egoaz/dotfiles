{
  "env": {
    "ANTHROPIC_MODEL": "claude-opus-4-7",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "true",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_USE_BEDROCK": "false",
    "DISABLE_TELEMETRY": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws ec2 describe-*:*)",
      "Bash(aws rds describe-*:*)",
      "Bash(aws dynamodb describe-*:*)",
      "Bash(aws dynamodb list-*:*)",
      "Bash(aws cloudformation describe-*:*)",
      "Bash(aws cloudformation list-*:*)",
      "Bash(aws elbv2 describe-*:*)",
      "Bash(aws autoscaling describe-*:*)",
      "Bash(aws application-autoscaling describe-*:*)",
      "Bash(aws route53 get-*:*)",
      "Bash(aws route53 list-*:*)",
      "Bash(aws acm describe-*:*)",
      "Bash(aws acm list-*:*)",
      "Bash(aws eks describe-*:*)",
      "Bash(aws eks list-*:*)",
      "Bash(aws ecs describe-*:*)",
      "Bash(aws ecs list-*:*)",
      "Bash(aws ecr describe-*:*)",
      "Bash(aws ecr list-*:*)",
      "Bash(aws elasticache describe-*:*)",
      "Bash(aws cloudwatch describe-*:*)",
      "Bash(aws cloudwatch list-*:*)",
      "Bash(aws cloudwatch get-metric-statistics:*)",
      "Bash(aws cloudwatch get-metric-data:*)",
      "Bash(aws cloudwatch get-insight-rule-report:*)",
      "Bash(aws cloudwatch list-managed-insight-rules:*)",
      "Bash(aws logs describe-*:*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(aws logs start-query:*)",
      "Bash(aws logs get-query-results:*)",
      "Bash(terraform version:*)",
      "Bash(terraform providers:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt -check:*)",
      "Bash(terraform workspace show:*)",
      "Bash(terraform graph:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 15 /System/Library/Sounds/Bottle.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 15 /System/Library/Sounds/Hero.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/code/oss/claude-status-line/target/release/statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "infra@infra-skills": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "Explanatory",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "  Turning to the Dark Side  "
    ]
  },
  "effortLevel": "high",
  "showThinkingSummaries": true
}
